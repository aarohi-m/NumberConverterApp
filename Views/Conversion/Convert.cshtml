@{
    ViewData["Title"] = "Number Converter";
}

<h2>Convert a Number</h2>

<form method="post" asp-action="ConvertNumber">
    <label for="inputValue">Enter Number:</label>
    <input type="text" name="inputValue" required />

    <label for="fromFormat">From Format:</label>
    <select name="fromFormat">
        <option value="decimal">Decimal</option>
        <option value="binary">Binary</option>
        <option value="hexadecimal">Hexadecimal</option>
        <option value="octal">Octal</option>
    </select>

    <label for="toFormat">To Format:</label>
    <select name="toFormat">
        <option value="decimal">Decimal</option>
        <option value="binary">Binary</option>
        <option value="hexadecimal">Hexadecimal</option>
        <option value="octal">Octal</option>
    </select>

    <button type="submit">Convert</button>
</form>